# Pinned versions/config for the kind e2e harness (Track F — TESTINFRA-1,
# docs/project/make-it-real-plan.md). Sourced by the hack/e2e/*.sh scripts;
# override any of these on the command line, e.g.
#   KIND_CLUSTER_NAME=my-cluster hack/e2e/kind-up.sh
KIND_CLUSTER_NAME="${KIND_CLUSTER_NAME:-jobtree-e2e}"
KIND_NODE_IMAGE="${KIND_NODE_IMAGE:-kindest/node:v1.36.1}"
E2E_IMAGE="${E2E_IMAGE:-jobtree-controller:e2e-local}"
E2E_SCHEDULER_IMAGE="${E2E_SCHEDULER_IMAGE:-jobtree-scheduler:e2e-local}"
E2E_NAMESPACE="${E2E_NAMESPACE:-jobtree-system}"
E2E_HELM_RELEASE="${E2E_HELM_RELEASE:-jobtree-e2e}"

# NOTE: sigs.k8s.io/jobset is NOT installed by this harness, and never will be.
# The JobSet prerequisite is PERMANENTLY RETIRED: a Run does not lower to a
# JobSet, because JobSet cannot express the spare swap or delta-funded elastic
# width. jobtree owns its pods; JobSet's shape survives only as a reference
# contract, documented on the emit path (controllers/kube.buildPod). See
# docs/project/remediation/R9-jobset-amendment.md.
