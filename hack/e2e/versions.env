# Pinned versions/config for the kind e2e harness (Track F — TESTINFRA-1,
# docs/project/make-it-real-plan.md). Sourced by the hack/e2e/*.sh scripts;
# override any of these on the command line, e.g.
#   KIND_CLUSTER_NAME=my-cluster hack/e2e/kind-up.sh
KIND_CLUSTER_NAME="${KIND_CLUSTER_NAME:-jobtree-e2e}"
KIND_NODE_IMAGE="${KIND_NODE_IMAGE:-kindest/node:v1.36.1}"
E2E_IMAGE="${E2E_IMAGE:-jobtree-controller:e2e-local}"
E2E_NAMESPACE="${E2E_NAMESPACE:-jobtree-system}"
E2E_HELM_RELEASE="${E2E_HELM_RELEASE:-jobtree-e2e}"

# NOTE: sigs.k8s.io/jobset is NOT installed by this harness today. That is
# Track B (JOBSET)'s prerequisite to add (JOBSET-3/JOBSET-10 in the master
# plan) once a Run actually lowers to a JobSet; until then there is no real
# workload for a JobSet controller to run, so installing it here would be
# scaffolding with nothing to exercise. See test/e2e/completion_test.go.
